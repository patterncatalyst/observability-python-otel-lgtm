# app/Containerfile — Red Hat UBI, multi-stage, rootless-friendly.
#
# Build stage installs Poetry + dependencies into a virtualenv; the runtime
# stage copies only that venv and the source, so build tooling never ships.
#
# PYTHON_BASE is an ARG so the image tracks the talk's target runtime. The
# intended target is Python 3.14; default below is the current UBI9 Python
# image. Swap to the 3.14 UBI tag once its availability is confirmed (tracked
# as an open question in the reconciliation plan).
ARG PYTHON_BASE=registry.access.redhat.com/ubi9/python-312:latest

# ── build stage ─────────────────────────────────────────────────────────────
FROM ${PYTHON_BASE} AS build
ENV POETRY_VERSION=1.8.5 \
    POETRY_VIRTUALENVS_IN_PROJECT=true \
    POETRY_NO_INTERACTION=1 \
    PIP_NO_CACHE_DIR=1
WORKDIR /app
RUN pip install --no-cache-dir "poetry==${POETRY_VERSION}"
COPY pyproject.toml ./
# poetry.lock is committed in a real run; copy it if present for reproducibility.
COPY app ./app
RUN poetry install --only main

# ── runtime stage ────────────────────────────────────────────────────────────
FROM ${PYTHON_BASE} AS runtime
WORKDIR /app
COPY --from=build /app/.venv /app/.venv
COPY --from=build /app/app /app/app
ENV PATH="/app/.venv/bin:${PATH}" \
    PYTHONUNBUFFERED=1
EXPOSE 8080
# Default command is overridden by compose (run-api / run-worker). Console
# scripts are defined in pyproject [tool.poetry.scripts].
CMD ["run-api"]
