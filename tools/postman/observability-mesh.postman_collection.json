{
  "info": {
    "name": "Observability Mesh (Python + OTel + LGTM)",
    "description": "Exercises the external edges of the demo mesh: the order REST API and the review GraphQL API. Each request is auto-traced; open Grafana > Explore > Tempo to follow the trace it produces.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "orderUrl", "value": "http://localhost:8080" },
    { "key": "reviewUrl", "value": "http://localhost:8081" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Place order (REST)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "if (body.order_id) { pm.collectionVariables.set('orderId', body.order_id); }",
              "pm.test('confirmed', () => pm.expect(body.status).to.eql('confirmed'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{orderUrl}}/orders", "host": ["{{orderUrl}}"], "path": ["orders"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer_id\": \"cust-42\",\n  \"sku\": \"WIDGET-001\",\n  \"quantity\": 1\n}"
        }
      }
    },
    {
      "name": "Place order — payment declined (REST)",
      "description": "quantity high enough to push the amount over the payment ceiling, producing an error trace.",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{orderUrl}}/orders", "host": ["{{orderUrl}}"], "path": ["orders"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customer_id\": \"cust-42\",\n  \"sku\": \"WIDGET-001\",\n  \"quantity\": 60\n}"
        }
      }
    },
    {
      "name": "Get order (REST)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{orderUrl}}/orders/{{orderId}}", "host": ["{{orderUrl}}"], "path": ["orders", "{{orderId}}"] }
      }
    },
    {
      "name": "Order + reviews (GraphQL)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{reviewUrl}}/graphql", "host": ["{{reviewUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"{ order(orderId: \\\"{{orderId}}\\\") { orderId sku status reviews { rating body } } }\"\n}"
        }
      }
    },
    {
      "name": "Reviews by SKU (GraphQL)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{reviewUrl}}/graphql", "host": ["{{reviewUrl}}"], "path": ["graphql"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"query\": \"{ reviews(sku: \\\"WIDGET-001\\\") { rating body } }\"\n}"
        }
      }
    }
  ]
}
